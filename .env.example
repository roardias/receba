# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
# Chave anon (frontend) ou service_role (backend). Para o scheduler/sync use service_role para evitar RLS (42501).
SUPABASE_KEY=sua_chave_anon_ou_service_role
# Recomendado para scheduler: use a service_role key (Dashboard > Settings > API). Ignora RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Criptografia para app_secret (execute: python gerar_chave_criptografia.py)
ENCRYPTION_KEY=

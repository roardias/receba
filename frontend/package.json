{
  "name": "receba-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,scheduler -c blue,green \"next dev\" \"npm run scheduler\"",
    "dev:next": "next dev",
    "dev:full": "concurrently -n next,scheduler -c blue,green \"next dev\" \"npm run scheduler\"",
    "scheduler": "cd .. && python -u scheduler_sync.py",
    "build": "next build",
    "start": "next start",
    "start:full": "concurrently -n next,scheduler -c blue,green \"next start\" \"npm run scheduler\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "fernet": "^0.3.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "next": "14.2.0",
    "papaparse": "^5.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "concurrently": "^8.2.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  }
}
